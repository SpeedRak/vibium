def f(x, n):
    sum = 0
    k = 0
    while x > 0:
        sum += x%10 * n ** k
        k += 1
        x //= 10
    return sum
g = 0
for x in range(6, 99):
    if (f(13152, x) + f(7025, 100) + x * 100**2) % 11 == 0:
        g += 1
print(g)

