from functools import *
@lru_cache(None)
def step(n):
    (a, b) = n
    return (a+2,b), (a, b+2), (a*2, b), (a, b*2)
def win(n):
    return sum(n) >= 65
def game(n):
    if any(win(n1) == 1 for n1 in step(n)): return 1 #ivan
    if any(game(n2) == 1 for n2 in step(n)): return 2 #pety

print([s for s in range(1, 60) if game((5, s)) == 2])


# Два игрока, Петя и Ваня, играют в следующую игру. Перед игроками лежат две кучи камней. Игроки ходят по очереди, первый ход делает Петя. За один ход игрок может добавить в одну из куч два камня или увеличить количество камней в куче в два раза. Чтобы делать ходы, у каждого игрока есть неограниченное количество камней. Игра завершается в тот момент, когда суммарное количество камней в кучах становится не менее 65. Победителем считается игрок, сделавший последний ход, т. е. первым получивший позицию, в которой в кучах будет 65 или больше камней.

