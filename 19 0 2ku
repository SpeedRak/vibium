from functools import *
from math import *

def step(n):
    (a, b) = n
    return (a + 10, b), (a * 2, b), (a, b+ 10), (a, b * 2)
def win(n):
    return prod(n) >= 541
    # (a, b) = n
    # return (a * b ) >= 541
def game(n): #chetaem snizu vverh
    if any(win(n1) == True for n1 in step(n)): return 1  #ivan
    if any(game(n2) == 1 for n2 in step(n)): return 2

print([s for s in range(1, 91) if game((6, s)) == 2])

