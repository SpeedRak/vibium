from turtle import *
tracer(0)
r = 20
lt(90)
down()
color
color('green')
for _ in range(4):
    fd(10*r), rt(90)
up()
rt(90)
fd(5*r)
lt(90)
down()
color('red')
for _ in range(4):
    fd(10*r), rt(90)

up()
for x in range(-10, 20):
    for y in range(-10, 15):
        goto(x*r, y*r)
        dot(4, 'black')
done()

# Исполнитель Черепаха передвигается по плоскости и оставляет след в виде линии. Черепаха может выполнять пять команд: Вперёд n (n – число), Направо m (m – число), Налево m (m – число), Поднять хвост, означающая переход к перемещению без рисования; Опустить хвост, означающая переход в режим рисования. По команде Вперёд n Черепаха перемещается вперёд на n единиц. По команде Направо m Черепаха поворачивается на месте на m градусов по часовой стрелке, при этом соответственно меняется направление дальнейшего движения. По команде Налево m Черепаха поворачивается на месте на m градусов против часовой стрелки, при этом соответственно меняется направление дальнейшего движения.

# В начальный момент Черепаха находится в начале координат и направлена вверх (вдоль положительного направления оси ординат). Хвост опущен.

