from functools import *
from math import *

def step(n):
    (a, b) = n
    return (a + 10, b), (a * 2, b), (a, b+ 10), (a, b * 2)
def win(n):
    return prod(n) >= 541
    # (a, b) = n
    # return (a * b ) >= 541
@lru_cache(None)
def game(n): #chetaem snizu vverh
    if any(win(n1) == True for n1 in step(n)): return 1  #ivan
    if all(game(n2) == 1 for n2 in step(n)): return 2
    if any(game(n3) == 2 for n3 in step(n)): return 3
    if all(game(n4) in (1, 3) for n4 in step(n)): return 4

print([s for s in range(1, 91) if game((6, s)) == 4])

