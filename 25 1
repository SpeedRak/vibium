from itertools import *
a = '1V2U4'
c = '0123456789'
for i in range(7):
    for V in c:
        for y in product(c, repeat=i):
            U = ''.join(y)
            x = (f'1{V}2{U}4')
            if int(x) % 2024 == 0 and int(x)**0.5 == int(int(x)**0.5):
                print(x, int(x) // 2024)
        
