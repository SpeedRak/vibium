f = open('24 3 file.txt').readline()
res = 0
slovo = ''
for i in f:
    slovo += i
    if slovo.count('AB') == 51:  # если в строке стало 51 AB, на 1 больше чем должно быть
        slovo = slovo[slovo.find('AB') + 1:] # отрезаем самую первую AB из текущей строки
#когда AB будет 51, мы сдвигаем слово вправо, убрав половину А из первого АВ,
#тем самым проходимся по всем максимальным словам в которых 50 АВ 

    if slovo.count('AB') == 50:
        res = max(res, len(slovo)) # сравниваем и, если нужно, заменяем максимальную длину

print(res)

