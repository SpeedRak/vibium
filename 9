f = open('9 file.csv')
k = 0
for i in f:
    a = list(map(int, i.split(';')))
    nepov = set(a)
    if len(nepov) != len(a):
        continue
    print('a:', a)
    for y in a:
        b = a[:] #когда мы делаем список2=список1, мы не делаем второй список, а просто даем ярлык, поэтому когда мы уменьшаем какой-либо список, уменьшается и второй. Делая список2=список1[:], мы создаем второй новый список, который не будет связан с первым.
        b.remove(y)
        # print(a, b, y)
        if (b[0] + b[1])/2 == (b[2] + b[3])/2 == y or (b[0] + b[2])/2 == (b[3] + b[1])/2 == y or (b[0] + b[3])/2 == (b[2] + b[1])/2 == y:
            k += 1
        
print(k)

