from functools import *
def step(n):
    return n +2, n +3, n * 3
def win(n):
    return n >= 313

@lru_cache(None)
def game(n):
    if any(win(n1)  for n1 in step(n)):  return 1 #проверка победы
    if all(game(n2) == 1   for n2 in step(n)): return 2
    if any(game(n3) == 2 for n3 in step(n)): return 3
    if all(game(n4) in (1, 3) for n4 in step(n)): return 4


print(sum([s for s in range(1, 313) if game(s) == 4]))

