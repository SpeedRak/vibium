from functools import *
@lru_cache(None)
def step(n):
    (a, b) = n
    return (a+2, b), (a*2, b), (a, b+2), (a, b*2)

@lru_cache(None)
def win(n):
    return sum(n) >= 65

@lru_cache(None)
def game(n):
    if any(win(n1) == True for n1 in step(n)): return 1
    if all(game(n2) == 1 for n2 in step(n)): return 2
    if any(game(n3) == 2 for n3 in step(n)): return 3
    if all(game(n4) in (1, 3) for n4 in step(n)): return 4
print([s for s in range(1, 60) if game((5, s)) == 4])

